# Optional: enables Clerk authentication UI.
VITE_CLERK_PUBLISHABLE_KEY=

# Optional: enables Supabase-backed scenario persistence.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Future/optional AI chatbot integration.
# Do not put provider API secrets in client-exposed VITE_ variables unless the key is intentionally user-provided and browser-scoped.
# Prefer a backend proxy for shared OpenRouter credentials.
# VITE_OPENROUTER_SITE_URL=
# VITE_OPENROUTER_APP_NAME=Dilution Model
